{
    "compilerOptions": {
        "target": "ES6",
        "module": "commonjs",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "outDir": "./dist",
        "resolveJsonModule": true,
        "noImplicitAny": true,
        "strictNullChecks": true,
        "strictFunctionTypes": true,
        "strictPropertyInitialization": true,
        "noImplicitThis": true,
        "alwaysStrict": true,
        "baseUrl": "./",
        "paths": {
            "*": ["*"]
        },
        "sourceMap": true
    },
    "include": ["src/**/*", "test/**/*", "config/**/*", "src/api/v1/schemas/branchSchema.ts", "src/api/v1/schemas/employeeSchema.ts"],
    "exclude": ["node_modules", "dist"]
}