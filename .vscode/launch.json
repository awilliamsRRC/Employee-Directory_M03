{
    "version": "0.2.0",
    "configurations": [
      {
        "type": "node",
        "request": "launch",
        "name": "Launch Jest Tests",
        "skipFiles": [
          "<node_internals>/**"
        ],
        "runtimeExecutable": "${workspaceFolder}/node_modules/jest/bin/jest.js",
        "args": [
          "--runInBand",
          "${workspaceFolder}/test/branchroutes.test.ts"
        ],
        "preLaunchTask": "tsc: build - tsconfig.json",
        "outFiles": [
          "${workspaceFolder}/dist/**/*.js"
        ],
        "sourceMaps": true,
        "runtimeArgs": [
          "--inspect-brk"  // This pauses the execution for debugging
        ]
      }
    ]
  }
  